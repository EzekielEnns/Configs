!use the command " xrdb -merge .Xresources " to color up xterm
! FONTS

!xterm*faceName: terminus-12
!Font type
!sudo apt-get install xfonts-terminus

xterm*font: *-fixed-*-*-*-18-*
!Font size

! Every shell is a login shell by default 
xterm*loginshell: true

! shell size
xterm*vt100*geometry: 110x24

!Scrollback
xterm*savelines: 16384

! double-click to select whole URLs 
xterm*charClass: 33:48,36-47:48,58-59:48,61:48,63-64:48,95:48,126:48 

xterm*eightBitInput: false
! stop mario from coming on screen

!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!xterm color stuff!!!!!!!!!!
!!!!!!!!!!!!!!!!!!!!!!!!!!!!

xterm*termName: xterm-color
! needed for xterm colours

!Allows term baesed apps to be directly effected 
xterm*termName: xterm-256color

xterm*foreground: rgb:18/ED/11
!the text color

xterm*background: rgb:00/00/00
! the currten controls
 
XTerm*cursorColor: rgb :a8/a8/a8
XTerm*pointerColor: rgb :2E/11/ED 
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

xterm*color1: rgb:a8/00/00
!

xterm*color2: rgb:00/a8/00
!

xterm*color3: rgb:a8/54/00
!

xterm*color4: rgb:00/00/a8
!dir

xterm*color5: rgb:a8/00/a8
!

xterm*color6: rgb:00/a8/a8
!dir?

xterm*color7: rgb:a8/a8/a8

xterm*color8: rgb:54/54/54
! 

xterm*color9: rgb:fc/54/54
!

xterm*color10: rgb:54/fc/54
!user@host

xterm*color11: rgb:fc/fc/54
!

xterm*color12: rgb:54/54/fc
!dir

xterm*color13: rgb:fc/54/fc
!

xterm*color14: rgb:54/fc/fc
!

xterm*color15: rgb:fc/fc/fc
!cuser(blinkything)

xterm*color16: rgb:fc/fc/fc
!
!!!!!!!!!!!!!!!!!!!!!!!!!!!


!bold or not bold
xterm*boldMode: false

! right hand side scrollbar...
xterm*rightScrollBar: true
xterm*ScrollBar: true

! stop output to terminal from jumping down to bottom of scroll again
xterm*scrollTtyOutput: false

XTerm*scaleHeight: 1.2
!space between lines


